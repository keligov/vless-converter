<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0f0f1a"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🔗 VLESS Converter"
            android:textColor="#7c6af7"
            android:textSize="22sp"
            android:textStyle="bold"
            android:gravity="center"
            android:paddingTop="16dp"
            android:paddingBottom="4dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Вставь JSON конфиг → получи VLESS ссылку"
            android:textColor="#888888"
            android:textSize="13sp"
            android:gravity="center"
            android:paddingBottom="16dp"/>

        <EditText
            android:id="@+id/etConfig"
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:background="#1a1a2e"
            android:textColor="#a0e0a0"
            android:textColorHint="#555555"
            android:hint="Вставь сюда JSON конфиг..."
            android:padding="12dp"
            android:gravity="top"
            android:inputType="textMultiLine"
            android:textSize="11sp"
            android:fontFamily="monospace"/>

        <Button
            android:id="@+id/btnConvert"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="12dp"
            android:text="⚡ Конвертировать"
            android:textColor="#ffffff"
            android:textSize="15sp"
            android:backgroundTint="#7c6af7"/>

        <LinearLayout
            android:id="@+id/resultCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#1a1a2e"
                android:padding="14dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="✅ VLESS Ссылка"
                    android:textColor="#7c6af7"
                    android:textStyle="bold"
                    android:textSize="13sp"
                    android:paddingBottom="8dp"/>

                <TextView
                    android:id="@+id/tvResult"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="#0d0d1a"
                    android:textColor="#80d0ff"
                    android:textSize="11sp"
                    android:padding="10dp"
                    android:fontFamily="monospace"
                    android:textIsSelectable="true"/>

                <Button
                    android:id="@+id/btnCopy"
                    android:layout_width="match_parent"
                    android:layout_height="42dp"
                    android:layout_marginTop="10dp"
                    android:text="📋 Копировать ссылку"
                    android:textColor="#ffffff"
                    android:backgroundTint="#333366"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#1a1a2e"
                android:padding="14dp"
                android:layout_marginTop="12dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="📋 Параметры"
                    android:textColor="#aaaaaa"
                    android:textStyle="bold"
                    android:textSize="13sp"
                    android:paddingBottom="8dp"/>

                <TextView
                    android:id="@+id/tvDetails"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="#e0e0f0"
                    android:textSize="12sp"
                    android:lineSpacingExtra="4dp"/>
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#1a2a1a"
                android:text="💡 Скопируй ссылку и импортируй в v2rayNG или NekoBox через «+» → «Import from clipboard»"
                android:textColor="#80c080"
                android:textSize="12sp"
                android:padding="12dp"
                android:layout_marginTop="12dp"/>

        </LinearLayout>
    </LinearLayout>
</ScrollView>
